{
  "name": "@appointment-saas/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export --platform android",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint \"App.tsx\" \"components/**/*.tsx\" \"screens/**/*.tsx\" \"lib/**/*.ts\"",
    "test": "jest"
  },
  "dependencies": {
    "@appointment-saas/shared": "workspace:*",
    "@babel/runtime": "^7.26.0",
    "@expo/metro-runtime": "~4.0.1",
    "expo": "^52.0.23",
    "expo-status-bar": "~2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.5",
    "react-native-web": "~0.19.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "eslint": "^9.17.0",
    "http-proxy-middleware": "^3.0.5",
    "jest": "^29.7.0",
    "jest-expo": "^52.0.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!.pnpm|((jest-)?react-native|@react-native|expo|expo-.+|@expo)/)",
      "node_modules/.pnpm/(?!(react-native|@react-native\\+js-polyfills|@react-native\\+.*|expo|expo-.+|@expo\\+.*)@)"
    ]
  }
}
